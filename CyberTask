from flask import Blueprint, render_template, request, redirect
from urllib.parse import quote
from .profiles import PROFILES

main = Blueprint("main", __name__)

@main.route("/", methods=["GET", "POST"])
def index():
    profiles = list(PROFILES.keys())
    selected_profile = request.form.get("profile", "Default")
    query = request.form.get("query", "")

    if request.method == "POST" and query.strip():
        encoded = quote(query.strip())
        sites = PROFILES.get(selected_profile, PROFILES["Default"])
        # For web: just render links instead of opening browser tabs
        links = [url + encoded for url in sites]
        return render_template(
            "index.html",
            profiles=profiles,
            selected_profile=selected_profile,
            query=query,
            links=links
        )

    return render_template(
        "index.html",
        profiles=profiles,
        selected_profile=selected_profile,
        query=query,
        links=[]
    )
from app import create_app

app = create_app()

if __name__ == "__main__":
    app.run(debug=True)
